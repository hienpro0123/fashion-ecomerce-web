rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().data.role == 'ADMIN';
    }

    function isOrderOwner() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function isCreatingOwnOrder() {
      return isSignedIn()
        && request.resource.data.userId == request.auth.uid;
    }

    function isCancellingOwnOrder() {
      return isOrderOwner()
        && resource.data.status == 'pending'
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.status == 'cancelled';
    }

    function adminOnlyOrderMutation() {
      return isAdmin()
        && request.resource.data.userId == resource.data.userId;
    }

    // This rule allows anyone on the internet to view, edit, and delete
    // all data in your Firestore database. It is useful for getting
    // started, but it is configured to expire after 30 days because it
    // leaves your app open to attackers. At that time, all client
    // requests to your Firestore database will be denied.
    //
    // Make sure to write security rules for your app before that time, or else
    // your app will lose access to your Firestore database
    //match /{document=**} {
    //  allow read, write: if request.time < timestamp.date(2020, 4, 21);
    //}
    
    match /users/{userId} {
      allow read, update: if request.auth.uid != null && request.auth.uid == userId;
    	allow create: if request.auth.uid != null;
    }
    
    match /products/{productId} {
      allow create,update,delete: if request.auth.uid != null;
    	allow read: if true;
    }

    match /orders/{orderId} {
      allow create: if isCreatingOwnOrder();
      allow read: if isAdmin() || isOrderOwner();
      allow update: if adminOnlyOrderMutation() || isCancellingOwnOrder();
      allow delete: if false;
    }
  }
}
